# =============================================================================
# HMS — EC2 production (no domain, public IP only)
# Copy on server:  cp deploy/env/ec2-public-ip.env.example .env
# Replace PUBLIC_IP, secrets, and S3 keys before use.
# NEVER commit a filled .env to git.
# =============================================================================

NODE_ENV=production
APP_NAME=HMS e-Register
APP_URL=http://PUBLIC_IP:3000
API_URL=http://PUBLIC_IP:4000
API_PREFIX=api/v1
PORT=4000

# Hostinger MySQL (remote — allow EC2 public IP in Hostinger remote MySQL)
DB_HOST=auth-db1274.hstgr.io
DB_PORT=3306
DB_USERNAME=u334425891_hms
DB_PASSWORD=YOUR_DB_PASSWORD
DB_DATABASE=u334425891_hms
DB_SSL=true
DB_SYNC=false

JWT_SECRET=YOUR_32_BYTE_HEX_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=YOUR_OTHER_32_BYTE_HEX_SECRET
JWT_REFRESH_EXPIRES_IN=7d

MFA_ISSUER=HMS e-Register
MFA_ENABLED=false

# AWS S3 (same region as EC2: us-east-1) — required for document uploads
S3_PROVIDER=aws
S3_REGION=us-east-1
S3_BUCKET=hms-documents-prod
S3_ACCESS_KEY=AKIA...
S3_SECRET_KEY=...

OCR_SERVICE_URL=http://127.0.0.1:5000
OCR_DEFAULT_ENGINE=tesseract

ENCRYPTION_KEY=YOUR_16_BYTE_HEX_SECRET

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Browser-facing URLs (set in root .env AND apps/web/.env.production before build)
# Without Nginx: use port 4000 for API. With Nginx on port 80: use http://PUBLIC_IP only.
NEXT_PUBLIC_API_URL=http://PUBLIC_IP:4000
NEXT_PUBLIC_WS_URL=ws://PUBLIC_IP:4000
