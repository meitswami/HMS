# Windows 11 — Offline / Local Development
# Copy to project root: copy deploy\env\windows.env.example .env

NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000

# Remote MySQL (Hostinger) or local
DB_HOST=auth-db1274.hstgr.io
DB_PORT=3306
DB_USERNAME=u334425891_hms
DB_PASSWORD=your_password_here
DB_DATABASE=u334425891_hms
DB_SSL=true
DB_SYNC=false

JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
ENCRYPTION_KEY=dev-encryption-key-32-chars-min

# Storage: skip Docker — uploads disabled until MinIO or S3 configured
# Option A: Docker Desktop + docker compose -f docker-compose.infra.yml up -d
S3_PROVIDER=minio
S3_ENDPOINT=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hms-documents
S3_USE_SSL=false

OCR_SERVICE_URL=http://localhost:5000

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
