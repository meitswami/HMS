# AWS EC2 Linux — Production WITH Docker (full stack in containers)
# Copy: cp deploy/env/ec2-docker.env.example .env

NODE_ENV=production
APP_URL=https://your-domain.gov.in
API_URL=https://your-domain.gov.in

DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=hms_user
DB_PASSWORD=strong_password
DB_DATABASE=hms
DB_SSL=true

JWT_SECRET=GENERATE_256_BIT_RANDOM_SECRET
JWT_REFRESH_SECRET=GENERATE_ANOTHER_RANDOM_SECRET
ENCRYPTION_KEY=GENERATE_32_BYTE_AES_KEY

# Inside Docker network — MinIO service name
S3_PROVIDER=minio
S3_ENDPOINT=minio
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hms-documents
S3_USE_SSL=false

REDIS_HOST=redis
OCR_SERVICE_URL=http://ocr-service:5000

NEXT_PUBLIC_API_URL=https://your-domain.gov.in
NEXT_PUBLIC_WS_URL=wss://your-domain.gov.in
