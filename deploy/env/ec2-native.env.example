# AWS EC2 Linux — Production WITHOUT Docker (recommended for limited RAM)
# Copy: cp deploy/env/ec2-native.env.example .env

NODE_ENV=production
APP_URL=https://your-domain.gov.in
API_URL=https://your-domain.gov.in
PORT=4000

# MySQL: RDS, remote Hostinger, or MySQL on same EC2
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USERNAME=hms_user
DB_PASSWORD=strong_password
DB_DATABASE=hms
DB_SSL=true
DB_SYNC=false

JWT_SECRET=GENERATE_256_BIT_RANDOM_SECRET
JWT_REFRESH_SECRET=GENERATE_ANOTHER_RANDOM_SECRET
ENCRYPTION_KEY=GENERATE_32_BYTE_AES_KEY

# Storage: AWS S3 (no MinIO container needed — saves ~200MB RAM)
S3_PROVIDER=aws
S3_REGION=ap-south-1
S3_BUCKET=hms-documents-prod
S3_ACCESS_KEY=AKIA...
S3_SECRET_KEY=...

OCR_SERVICE_URL=http://127.0.0.1:5000

# Public URLs for browser
NEXT_PUBLIC_API_URL=https://your-domain.gov.in
NEXT_PUBLIC_WS_URL=wss://your-domain.gov.in

# Notifications (optional)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
