# HMS Portable — self-contained Windows distribution
# Copied to dist/portable/.env during build

NODE_ENV=production
APP_URL=http://127.0.0.1:3000
API_URL=http://127.0.0.1:4000
PORT=4000
WEB_PORT=3000

# Embedded MariaDB (launcher overrides when mariadb/ is bundled)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=hms
DB_SSL=false
DB_SYNC=false

JWT_SECRET=portable-change-this-secret-in-production
JWT_REFRESH_SECRET=portable-refresh-change-in-production
ENCRYPTION_KEY=portable-encryption-key-32chars

# Local filesystem storage (no MinIO/Docker required)
S3_PROVIDER=local
LOCAL_STORAGE_PATH=data/uploads
S3_BUCKET=hms-documents

# OCR optional — install Python separately or skip OCR features
OCR_SERVICE_URL=http://127.0.0.1:5000
OCR_DEFAULT_ENGINE=tesseract

NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:4000
