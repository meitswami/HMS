# =============================================================================
# AI Hotel Register & Police Intelligence Command Centre
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# Application
NODE_ENV=development
APP_NAME=HMS e-Register
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PREFIX=api/v1

# MySQL Database (Hostinger / Remote)
DB_HOST=auth-db1274.hstgr.io
DB_PORT=3306
DB_USERNAME=u334425891_hms
DB_PASSWORD=your_password_here
DB_DATABASE=u334425891_hms
DB_SSL=true
DB_SYNC=false

# JWT Authentication
JWT_SECRET=change-this-to-a-256-bit-random-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

# MFA
MFA_ISSUER=HMS e-Register
MFA_ENABLED=true

# Object Storage — minio (local/Docker) or aws (EC2 without Docker)
# See deploy/env/*.env.example for mode-specific templates
S3_PROVIDER=minio
S3_ENDPOINT=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hms-documents
S3_USE_SSL=false
S3_REGION=ap-south-1

# Redis (sessions, queues, pub/sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OCR Service
OCR_SERVICE_URL=http://localhost:5000
OCR_DEFAULT_ENGINE=paddle

# AI / LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
FCM_SERVER_KEY=

# Security
ENCRYPTION_KEY=32-byte-aes-encryption-key-here
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
IP_WHITELIST_ENABLED=false

# Multi-tenant
DEFAULT_TENANT_ID=default
